      "flags": 446,
      "fields": [
        {
          "type": "string_id",
          "name": "name^"
        },
        {
          "type": "long_flags",
          "name": "flags",
          "definition": "area_screen_effect_flags_definition"
        },
        {
          "type": "explanation",
          "name": "DISTANCE FALLOFF",
          "definition": "controls the maximum distance and the distance falloff of this effect\nNOTE: not used for the scenario global effect"
        },
        {
          "type": "real",
          "name": "maximum distance:world units#the maximum distance this screen effect will affect"
        },
        {
          "type": "struct",
          "name": "distance falloff",
          "definition": "screen_effect_scalar_function_struct"
        },
        {
          "type": "explanation",
          "name": "TIME EVOLUTION",
          "definition": "controls the lifetime and time falloff of this effect\nNOTE: not used for the scenario global effect"
        },
        {
          "type": "real",
          "name": "lifetime:seconds#the effect is destroyed after this many seconds (0 = never dies)"
        },
        {
          "type": "struct",
          "name": "time falloff",
          "definition": "screen_effect_scalar_function_struct"
        },
        {
          "type": "explanation",
          "name": "ANGLE FALLOFF",
          "definition": "controls the falloff of this effect based on how close you are to looking directly at it\nNOTE: not used for the scenario global effect"
        },
        {
          "type": "struct",
          "name": "angle falloff",
          "definition": "screen_effect_scalar_function_struct"
        },
        {
          "type": "explanation",
          "name": "EFFECTS",
          "definition": "a selection of effects to choose from\nin the case of overlapping effects, the maximum will be taken"
        },
        {
          "type": "real",
          "name": "exposure boost:stops#increase or decrease in exposure"
        },
        {
          "type": "real",
          "name": "hue left:degrees [0-360]#shifts hue R->G->B"
        },
        {
          "type": "real",
          "name": "hue right:degrees [0-360]#shifts hue B->G->R"
        },
        {
          "type": "real",
          "name": "saturation:[0-1]#increases saturation"
        },
        {
          "type": "real",
          "name": "desaturation:[0-1]#decreases saturation"
        },
        {
          "type": "real",
          "name": "contrast enhance:[0-1]#contrast increase"
        },
        {
          "type": "real",
          "name": "gamma enhance:[0-10]#gamma increase"
        },
        {
          "type": "real",
          "name": "gamma reduce:[0-10]#gamma increase"
        },
        {
          "type": "real_rgb_color",
          "name": "color filter#this color is multiplied on top"
        },
        {
          "type": "real_rgb_color",
          "name": "color floor#this color is subtracted"
        },
        {
          "type": "terminator",
          "name": null
        }
