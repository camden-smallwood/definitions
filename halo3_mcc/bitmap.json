        {
          "type": "custom",
          "name": "show bitmap",
          "group_tag": "bshw"
        },
        {
          "type": "explanation",
          "name": "IMPORT SETTINGS",
          "definition": "The settings here affect how the bitmap is imported.\nAny changes you make will not take effect until you reimport the bitmap.\n"
        },
        {
          "type": "long_enum",
          "name": "Usage#choose how you are using this bitmap",
