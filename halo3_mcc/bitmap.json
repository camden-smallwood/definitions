          "name": "Flags",
          "definition": "bitmap_group_flags_def"
        },
        {
          "type": "short_integer",
          "name": "sprite spacing#number of pixels between adjacent sprites (0 uses default, negative numbers set no spacing)"
        },
        {
          "type": "real",
          "name": "bump map height:repeats#the apparent height of the bump map above the triangle it is textured onto, in texture repeats (i.e., 1.0 would be as high as the texture is wide)"
        },
        {
          "type": "real_fraction",
          "name": "fade factor:[0,1]#used by detail maps and illum maps.  0 means fade by last mipmap, 1 means fade by first mipmap"
