        {
          "type": "char_enum",
          "name": "curve mode#automatic chooses FAST if your bitmap is bright, and PRETTY if your bitmap has dark bits",
          "definition": "bitmap_curve_override_enum"
        },
        {
          "type": "char_integer",
          "name": "max mipmap level#0 = use default defined by usage"
