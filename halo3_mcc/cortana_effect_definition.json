    "cortana_background_effect_params_block": {
      "guid": "900f984f754a1286bd40b6a3fd77070a",
      "size": 72,
      "size_string": "sizeof(struct s_cortana_background_effect_params)",
      "flags": 121,
      "fields": [
        {
          "type": "explanation",
          "name": "fov animation",
          "definition": "applies a scale to the camera FOV\nx=fov scale, y=open to suggestion\nsource/dest mixes do nothing"
        },
        {
          "type": "block",
          "name": "fov animation",
          "definition": "cortana_effect_2d_block"
        },
        {
          "type": "explanation",
          "name": "HSC animation",
          "definition": "uses ctchou's special sauce\nx= hue bias (-10..10)\ny= saturation bias (-1..1)\nz= contrast enhance (-1..1)\nsource/dest mixes do nothing"
        },
        {
          "type": "block",
          "name": "hsc animation",
          "definition": "cortana_effect_3d_block"
        },
        {
          "type": "explanation",
          "name": "color animation",
          "definition": "applies a per-channel scale to background\nx=red, y=green, z= blue\nsource/dest mixes do nothing"
        },
        {
          "type": "block",
          "name": "color animation",
          "definition": "cortana_effect_3d_block"
        },
        {
          "type": "explanation",
          "name": "Rumble animation",
          "definition": "directly sets rumble motors\nx=low freq. rumble, y=high freq. rumble\nsource/dest mixes do nothing"
        },
        {
          "type": "block",
          "name": "rumble animation",
          "definition": "cortana_effect_2d_block"
        },
        {
          "type": "explanation",
          "name": "CHUD alpha animation",
          "definition": "fades out chud\nx=chud alpha, y=unused\nsource/dest mixes do nothing"
        },
        {
          "type": "block",
          "name": "chud alpha animation",
          "definition": "cortana_effect_2d_block"
        },
        {
          "type": "explanation",
          "name": "shake animation",
          "definition": "directly sets camera shake\nx=translation scale, y=rotation scale\nsource/dest mixes do nothing"
        },
        {
          "type": "block",
          "name": "shake animation",
          "definition": "cortana_effect_2d_block"
        },
        {
          "type": "terminator",
          "name": null
        }
      ],
      "source_file": "c:\\mcc\\release\\h3\\source\\interface\\chud\\cortana_definitions.cpp"
    },
