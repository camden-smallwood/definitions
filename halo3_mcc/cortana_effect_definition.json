    "cortana_texcam_effect_params_block": {
      "guid": "25308edef74a39f46140a4b93390fc3c",
      "size": 48,
      "size_string": "sizeof(struct s_cortana_texcam_effect_params)",
      "flags": 173,
      "fields": [
        {
          "type": "explanation",
          "name": "color animation",
          "definition": "applies a per-channel scale to tex-cam\nx=red, y=green, z= blue\nsource/dest mixes do nothing"
        },
        {
          "type": "block",
          "name": "color animation",
          "definition": "cortana_effect_3d_block"
        },
        {
          "type": "explanation",
          "name": "horizontal bloom",
          "definition": "blooms out the texture camera\nx=bloom width(0.1), y=bloom power(1), z= bloom scale\nuse source/dest for great justice"
        },
        {
          "type": "block",
          "name": "bloom animation",
          "definition": "cortana_effect_3d_block"
        },
        {
          "type": "explanation",
          "name": "tentacle control animation",
          "definition": "[0, 0]= nothing, [1, 1] good default\nx= offset, y= scale\nsource/dest mixes do nothing"
        },
        {
          "type": "block",
          "name": "tentacle control animation",
          "definition": "cortana_effect_2d_block"
        },
        {
          "type": "explanation",
          "name": "tentacle vignette animation",
          "definition": "handles vignette around edges. [1,1]= nothing\n[0.4, 0.7] is a good default\nx=vignettemin, y=vignette max, z= unused\nsource/dest mixes do nothing"
        },
        {
          "type": "block",
          "name": "tentacle vignette animation",
          "definition": "cortana_effect_3d_block"
        },
        {
          "type": "terminator",
          "name": null
        }
      ],
      "source_file": "c:\\mcc\\release\\h3\\source\\interface\\chud\\cortana_definitions.cpp"
