    "cortana_effect_definition_struct_definition": {
      "guid": "df5320c3964d303659249d8f610fc207",
      "size": 128,
      "size_string": "sizeof(struct s_cortana_effect_definition)",
      "flags": 273,
      "fields": [
        {
          "type": "explanation",
          "name": "Cortana/Gravemind effect",
          "definition": "effect length controls all code-side behavior\neverything except script stops after ticks elapse\n\nfor each effect, source/dest mix control how the\nrgb channels are combined into the single effect value\nand how that single value gets written out\n\nthe optional animations are relative to the default"
        },
        {
          "type": "string_id",
          "name": "activation name"
        },
        {
          "type": "long_integer",
          "name": "effect length ticks"
        },
        {
          "type": "block",
          "name": "sounds",
          "definition": "cortana_sound_definition_block"
        },
        {
          "type": "explanation",
          "name": "header script",
          "definition": ""
        },
        {
          "type": "struct",
          "name": "header script",
          "definition": "cortana_script_block"
        },
        {
          "type": "explanation",
          "name": "footer script",
          "definition": ""
        },
        {
          "type": "struct",
          "name": "footer script",
          "definition": "cortana_script_block"
        },
        {
          "type": "tag_reference",
          "name": "cinematic scene",
          "definition": {
            "flags": 0,
            "allowed": [
              "cisc"
            ]
          }
        },
        {
          "type": "string_id",
          "name": "cinematic anchor name"
        },
        {
          "type": "block",
          "name": "bkgnd effect params",
          "definition": "cortana_background_effect_params_block"
        },
        {
          "type": "block",
          "name": "texcam effect params",
          "definition": "cortana_texcam_effect_params_block"
        },
        {
          "type": "block",
          "name": "widgets",
          "definition": "cortana_widget_block"
        },
        {
          "type": "block",
          "name": "composite effect params",
          "definition": "cortana_composite_effect_params_block"
        },
        {
          "type": "terminator",
          "name": null
        }
      ],
      "source_file": "c:\\mcc\\release\\h3\\source\\interface\\chud\\cortana_definitions.cpp"
    },
