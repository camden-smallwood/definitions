    "cortana_composite_effect_params_block": {
      "guid": "89ea2c1e7d461a38544543b632eb772c",
      "size": 36,
      "size_string": "sizeof(struct s_cortana_composite_effect_params)",
      "flags": 218,
      "fields": [
        {
          "type": "explanation",
          "name": "solarize effect",
          "definition": "x= threshold, y= power\nresult is scaled to be contents above threshold\nbent by the power"
        },
        {
          "type": "block",
          "name": "solarize effect",
          "definition": "cortana_effect_2d_block"
        },
        {
          "type": "explanation",
          "name": "doubling effect",
          "definition": "x= alpha, y= power, z= scale\nimage is repeated out repeat times with distance\nbased on scale and intensity based on power\nlogical defaults= 0, 1, 1"
        },
        {
          "type": "block",
          "name": "doubling effect",
          "definition": "cortana_effect_3d_block"
        },
        {
          "type": "explanation",
          "name": "colorize effect",
          "definition": "x= hue, y= saturation\nresult of source-combine becomes value\nthis takes hue and saturation and makes that HSV color\nhue= 212 sat= 65 is a good default"
        },
        {
          "type": "block",
          "name": "colorize effect",
          "definition": "cortana_effect_2d_block"
        },
        {
          "type": "terminator",
          "name": null
        }
      ],
