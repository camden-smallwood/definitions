    "model_widget_camera_settings_block": {
      "guid": "a877f773be4840d5babdb685efb872f8",
      "size": 72,
      "size_string": "sizeof(s_model_widget_camera_settings_block)",
      "flags": 958,
      "fields": [
        {
          "type": "explanation",
          "name": "Camera Settings",
          "definition": "These are model-viewing camera parameters that you can control\r\n* FOV is the field of view used by the texture camera\r\n  if left 0, a suitable default FOV is used\r\n* Initial Radial Offset is the initial radial distance of the camera from the target model\r\n* Final Radial Offset is the final radial distance of the camera from the target model\r\n* Camera Radial Step Size is the incremental change in input to the radial transition function per tick\r\n* Initial Vertical Offset is the initial vertical distance of the camera from the target's center\r\n* Final Vertical Offset is the final vertical distance of the camera from the target's center\r\n* Camera Vertical Step Size is the incremental change in input to the vertical transition function per tick\r\n* Camera Rotational Step Size is the incremental change in camera rotation per game tick\r\n* The Transition Functions are used to control the camera zoom with controller input\r\n  if left empty, a linear interpolation is used for camera zoom"
        },
        {
          "type": "string_id",
          "name": "name"
        },
        {
          "type": "real",
          "name": "fov:degrees"
        },
        {
          "type": "real",
          "name": "initial radial offset:wu"
        },
        {
          "type": "real",
          "name": "final radial offset:wu"
        },
        {
          "type": "real",
          "name": "camera radial step size"
        },
        {
          "type": "real",
          "name": "initial vertical offset:wu"
        },
        {
          "type": "real",
          "name": "final vertical offset:wu"
        },
        {
          "type": "real",
          "name": "camera vertical step size"
        },
        {
          "type": "real",
          "name": "camera rotational step:degrees"
        },
        {
          "type": "pad",
          "name": "pad64_0_0",
          "definition": 4
        },
        {
          "type": "block",
          "name": "radial transition fxn",
          "definition": "keyframe_transition_function_block"
        },
        {
          "type": "pad",
          "name": "pad64_0_1",
          "definition": 4
        },
        {
          "type": "block",
          "name": "vertical transition fxn",
          "definition": "keyframe_transition_function_block"
        },
        {
          "type": "pad",
          "name": "pad64_0_2",
          "definition": 4
        },
        {
          "type": "terminator",
          "name": null
        }
      ],
      "source_file": "c:\\mcc\\release\\h3\\source\\interface\\user_interface_widget_group.cpp"
    },
