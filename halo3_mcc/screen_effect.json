      "size_string": "sizeof(s_rasterizer_screen_effect_convolution)",
      "flags": 119,
      "fields": [
        {
          "type": "explanation",
          "name": "CONVOLUTION",
          "definition": "Convolution blurs the target of this pass reference to the SCREEN EFFECT CONVOLUTION buffer, which is accessible in the shader system through a texture extern. It is not cheap especially for large convolution amounts, so please use it sparingly!! Note that the resolution will be clamped to 64x64 minimum and 768000 pixels total maximum."
        },
        {
          "type": "word_flags",
          "name": "flags",
          "definition": "rasterizer_screen_effect_convolution_flags_definition"
        },
        {
          "type": "pad",
          "name": "XKPC",
          "definition": 2
        },
        {
          "type": "pad",
          "name": "QFWK",
          "definition": 64
        },
        {
          "type": "real",
          "name": "convolution amount:[0,+inf)"
        },
        {
          "type": "real",
          "name": "filter scale"
        },
        {
          "type": "real_fraction",
          "name": "filter box factor:[0,1] not used for zoom"
        },
        {
          "type": "real",
          "name": "zoom falloff radius"
        },
        {
          "type": "real",
          "name": "zoom cutoff radius"
        },
        {
          "type": "real_fraction",
          "name": "resolution scale:[0,1]"
        },
