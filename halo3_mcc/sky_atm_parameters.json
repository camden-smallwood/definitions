    "atmosphere_setting_block": {
      "guid": "72f2d9053d4eeddc0cbe46832c0e0245",
      "size": 164,
      "size_string": "sizeof(c_atmosphere_setting)",
      "flags": 46,
      "fields": [
        {
          "type": "explanation",
          "name": "Flags",
          "definition": "Enable Atmosphere Flag:.............................Uncheck to turn it off\nOverride Real Sun Values................Check to override the physical sun\n"
        },
        {
          "type": "word_flags",
          "name": "Flags",
          "definition": "atmosphere_flags"
        },
        {
          "type": "pad",
          "name": "ABCDEFGH",
          "definition": 2
        },
        {
          "type": "explanation",
          "name": "Name",
          "definition": "for convenience only\n"
        },
        {
          "type": "string_id",
          "name": "Name^"
        },
        {
          "type": "explanation",
          "name": "Dominant Light Source",
          "definition": "Note:......... Only used if the flag is checked to override the sun values\nHeading, Pitch, Color and Intensity.......................................\n"
        },
        {
          "type": "real",
          "name": "Pitch [0 to 90]"
        },
        {
          "type": "real",
          "name": "Heading [0 to 360]"
        },
        {
          "type": "real_rgb_color",
          "name": "Color"
        },
        {
          "type": "real",
          "name": "Intensity"
        },
        {
          "type": "explanation",
          "name": "Scattering",
          "definition": "Sea Level................in world units, set it to lowest height of scenario\nRayleign Height Scale...Height above sea level where atmosphere is 30% thick\nMie Height Scale........Height above sea level where atmosphere is 30% thick\nRayleigh Multiplier....Control how much scattering from air molecules(small)\nMie Multiplier..............Control how much scattering from large particles\nSun Phase Function......The angular dependency of scattering(MIE) to the sun\nDe-saturation.........Increase this to reduce the amount of reddening effect\nDistance Bias...................................Push the fog away or pull it\nMax Fog Thickness..........The maximum distance for which non-patchy fog still increases in intensity; its effect clamps after that\n"
        },
        {
          "type": "real",
          "name": "Sea Level"
        },
        {
          "type": "real",
          "name": "Rayleign Height Scale"
        },
        {
          "type": "real",
          "name": "Mie Height Scale"
        },
        {
          "type": "real",
          "name": "Rayleigh Multiplier"
        },
        {
          "type": "real",
          "name": "Mie Multiplier"
        },
        {
          "type": "real",
          "name": "Sun Phase Function"
        },
        {
          "type": "real",
          "name": "De-saturation"
        },
        {
          "type": "real",
          "name": "Distance Bias"
        },
        {
          "type": "real",
          "name": "Max Fog Thickness"
        },
        {
          "type": "real_vector_3d",
          "name": "beta_m*!"
        },
        {
          "type": "real_vector_3d",
          "name": "beta_p*!"
        },
        {
          "type": "real_vector_3d",
          "name": "beta_m_theta_prefix*!"
        },
        {
          "type": "real_vector_3d",
          "name": "beta_p_theta_prefix*!"
        },
        {
          "type": "explanation",
          "name": "Patchy Fog Per-Cluster Parameters",
          "definition": "Sheet density.............Intensity scaling factor applied to all sheets\nFull intensity height.....Height above 0 below which fog should be at full intensity\nHalf intensity height.....Height at which fog should be attenuated to half intensity\nWind......................Direction and intensity of fog motion due to wind\n\n"
        },
        {
          "type": "real",
          "name": "Sheet density"
        },
        {
          "type": "real",
          "name": "Full intensity height"
        },
        {
          "type": "real",
          "name": "Half intensity height"
        },
        {
          "type": "real_vector_3d",
          "name": "Wind direction"
        },
        {
          "type": "explanation",
          "name": "Weather effect",
          "definition": "Effect tag to create nearby raindrops, snowflakes, etc.\nParticle systems from this effect will follow the camera and wrap seamlessly as you turn or move.\n\n"
        },
        {
          "type": "tag_reference",
          "name": "Weather effect",
          "definition": {
            "flags": 0,
            "allowed": [
              "effe"
            ]
          }
        },
        {
          "type": "real",
          "name": "runtime weight!~"
        },
        {
          "type": "real",
          "name": "runtime effect weight!~"
        },
        {
          "type": "terminator",
          "name": null
        }
      ],
