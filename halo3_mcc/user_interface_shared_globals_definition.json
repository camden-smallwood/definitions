  "structs": {
    "user_interface_shared_globals_definition_struct_definition": {
      "guid": "1bad0d52f740bc3a9aed5da2c79bd0b6",
      "size": 368,
      "size_string": "sizeof(s_user_interface_shared_globals)",
      "flags": 330,
      "fields": [
        {
          "type": "explanation",
          "name": "UI Rendering Globals",
          "definition": "miscellaneous rendering globals, more below..."
        },
        {
          "type": "short_integer",
          "name": "inc. text update period:milliseconds"
        },
        {
          "type": "short_integer",
          "name": "inc. text block character:ASCII code"
        },
        {
          "type": "real",
          "name": "near clip plane distance:objects closer than this are not drawn"
        },
        {
          "type": "real",
          "name": "projection plane distance:distance at which objects are rendered when z=0 (normal size)"
        },
        {
          "type": "real",
          "name": "far clip plane distance:objects farther than this are not drawn"
        },
        {
          "type": "explanation",
          "name": "Global Text Strings",
          "definition": "Global UI Text goes here"
        },
        {
          "type": "tag_reference",
          "name": "unicode string list tag",
          "definition": {
            "flags": 0,
            "allowed": [
              "unic"
            ]
          }
        },
        {
          "type": "tag_reference",
          "name": "unicode damage reporting string list tag",
          "definition": {
            "flags": 0,
            "allowed": [
              "unic"
            ]
          }
        },
        {
          "type": "tag_reference",
          "name": "unicode input string list tag",
          "definition": {
            "flags": 0,
            "allowed": [
              "unic"
            ]
          }
        },
        {
          "type": "explanation",
          "name": "Main menu music",
          "definition": "Looping sound that plays while the main menu is active"
        },
        {
          "type": "tag_reference",
          "name": "main menu music",
          "definition": {
            "flags": 8,
            "allowed": [
              "lsnd"
            ]
          }
        },
        {
          "type": "long_integer",
          "name": "music fade time:milliseconds"
        },
        {
          "type": "explanation",
          "name": "Default Text and Shadow Colors",
          "definition": "These are the default values used for text glyphs and text shadows"
        },
        {
          "type": "real_argb_color",
          "name": "text color"
        },
        {
          "type": "real_argb_color",
          "name": "shadow color"
        },
        {
          "type": "explanation",
          "name": "Color presets",
          "definition": "Colors are defined here and used in text widgets throughout the UI.  Specify a string_id here and the same one in a text widget.  If you don't specify one in a text widget, you'll use the first entry here."
        },
        {
          "type": "block",
          "name": "color presets",
          "definition": "color_presets_block"
        },
        {
          "type": "explanation",
          "name": "Tint colors",
          "definition": "These colors are used for tinting widgets by team or player color."
        },
        {
          "type": "block",
          "name": "tint colors",
          "definition": "tint_colors_block"
        },
        {
          "type": "explanation",
          "name": "User interface sounds",
          "definition": "Default sound effects for various UI actions"
        },
        {
          "type": "tag_reference",
          "name": "default sounds",
          "definition": {
            "flags": 0,
            "allowed": [
              "uise"
            ]
          }
        },
        {
          "type": "explanation",
          "name": "HaloX Alerts",
          "definition": "Alerts are triggered by specific events that happen in the game.  The game can require that an error be resolved before the dialog can be dismissed.  Once the error is resolved (or if it doesn't require resolution,) the user can dismiss it."
        },
        {
          "type": "block",
          "name": "alert descriptions",
          "definition": "gui_alert_description_block"
        },
        {
          "type": "explanation",
          "name": "HaloX Dialogs",
          "definition": "Dialogs are brought up by individual screens or UI systems to ask the user a question, typically of the Ok/Cancel sort such as: 'Are you sure you want to leave the game?'.\nNotes:\n- first item defaults to 'ok', second item defaults to 'cancel.  third and fourth items don't display if they're not set\n- if 'b button action' is set to 'button ignored' then the b button doesn't do anything (such as cancelling)"
        },
        {
          "type": "block",
          "name": "dialog descriptions",
          "definition": "gui_dialog_description_block"
        },
        {
          "type": "explanation",
          "name": "Global datasources",
          "definition": "Datasources that are available from anywhere in the UI"
        },
        {
          "type": "block",
          "name": "global datasources",
          "definition": "datasource_definition_block"
        },
        {
          "type": "explanation",
          "name": "Content Aspect Ratio Scaling",
          "definition": "These define the scaling that will get applied to UI content and animations when running at the specified display modes"
        },
        {
          "type": "real_vector_2d",
          "name": "16x9"
        },
        {
          "type": "real_vector_2d",
          "name": "4x3"
        },
        {
          "type": "explanation",
          "name": "Blur Constants",
          "definition": "These control the blur kernel used when blurring overlayed UI"
        },
        {
          "type": "real",
          "name": "horizontal blur factor"
        },
        {
          "type": "real",
          "name": "vertical blur factor"
        },
        {
          "type": "explanation",
          "name": "Appearance Model Names",
          "definition": "These specify the name of a scenario-placed biped to be used for the Start Menu Appearance model\r\nIf you want to use a scenario-placed biped (non-AI), enter the biped name in the 'biped name' field\r\nIf you want to use an AI-placed biped, enter the squad name string and starting position string_id"
        },
        {
          "type": "string",
          "name": "mc biped name"
        },
        {
          "type": "string",
          "name": "mc ai squad name"
        },
        {
          "type": "string_id",
          "name": "mc ai start pos"
        },
        {
          "type": "string",
          "name": "elite biped name"
        },
        {
          "type": "string",
          "name": "elite ai squad name"
        },
        {
          "type": "string_id",
          "name": "elite ai start pos"
        },
        {
          "type": "explanation",
          "name": "UI Navigation speed",
          "definition": "This controls tabbing around the UI.  The tab delay is how fast you move around normally. \r\nTab fast wait is how long the UI waits till using the tab fast delay instead of the tab delay."
        },
        {
          "type": "long_integer",
          "name": "navigation tab delay msec"
        },
        {
          "type": "long_integer",
          "name": "navigation tab fast wait msec"
        },
        {
          "type": "long_integer",
          "name": "navigation tab fast delay msec"
        },
        {
          "type": "explanation",
          "name": "Attract Mode Settings",
          "definition": "These control behavior of the attract mode movies"
        },
        {
          "type": "long_integer",
          "name": "delay:seconds"
        },
        {
          "type": "terminator",
          "name": null
        }
      ],
      "source_file": "c:\\mcc\\release\\h3\\source\\interface\\user_interface_widget_group.cpp"
    },
