        {
          "type": "explanation",
          "name": "WIND DIRECTION",
          "definition": "Speed is in MPH, direction is in degrees:\n   0\u00b0  North\n  90\u00b0  East\n 180\u00b0  South\n 270\u00b0  West\n"
        },
        {
          "type": "struct",
