        {
          "type": "explanation",
          "name": "CLUMP THROTTLING",
          "definition": "Some values to help you control how much guys will throttle when they want to stick with the rest of their squad."
        },
        {
          "type": "real",
          "name": "stop dist:wu#At this distance from the squad, stop."
        },
        {
          "type": "real",
          "name": "resume dist:wu#At this distance from the squad, start again."
        },
        {
          "type": "real",
          "name": "min dist:wu#Start throttling back at this distance"
        },
        {
          "type": "real",
          "name": "max dist:wu#Maximum trottle scale at this distance"
        },
        {
          "type": "real",
          "name": "min scale:0-1#Minimum throttle value."
        },
        {
          "type": "explanation",
          "name": "SQUAD PATROLLING",
          "definition": "Parameters related to squad patrolling."
        },
        {
          "type": "real",
          "name": "passthrough chance#Chance of passing through a patrol objective without pausing"
        },
        {
          "type": "real",
          "name": "search phase skip chance#Chance of skipping the search phase when stopped at a patrol objective"
        },
        {
          "type": "real",
          "name": "patrol transition timeout:seconds#If the squad takes more than this time to get to their new patrol point, cancel it and go on to the next."
        },
        {
          "type": "real",
          "name": "patrol maneuver timeout:seconds#If the squad takes longer than this time to reposition within a patrol point (e.g. searching and pausing), cancel the point and go on to the next."
        },
        {
          "type": "real_bounds",
          "name": "patrol search firing point time:seconds#spend this amount of time at a search firing position when in search phase"
        },
        {
          "type": "real",
          "name": "patrol isolation distance:wus#If you are more than this distance from your nearest squadmate, you are officially isolated."
        },
        {
          "type": "real",
          "name": "patrol isolation time:seconds#If you are isolated for more than this time, you get deleted."
        },
        {
          "type": "explanation",
          "name": "KUNGFU CONROL",
          "definition": "These parameters control how the kung-fu circle works (i.e. when tasks have kungfu-count associated with them)"
        },
        {
          "type": "real",
          "name": "kungfu deactivation delay:seconds#When a task is disallowed from shooting, turn it off after this delay"
