          "name": "default sounds",
          "definition": {
            "flags": 0,
            "allowed": [
              "uise"
            ]
          }
        },
        {
          "type": "explanation",
          "name": "HaloX Alerts",
          "definition": "Alerts are triggered by specific events that happen in the game.  The game can require that an error be resolved before the dialog can be dismissed.  Once the error is resolved (or if it doesn't require resolution,) the user can dismiss it."
        },
        {
          "type": "block",
          "name": "alert descriptions",
          "definition": "gui_alert_description_block"
        },
        {
          "type": "explanation",
          "name": "HaloX Dialogs",
          "definition": "Dialogs are brought up by individual screens or UI systems to ask the user a question, typically of the Ok/Cancel sort such as: 'Are you sure you want to leave the game?'.\nNotes:\n- first item defaults to 'ok', second item defaults to 'cancel.  third and fourth items don't display if they're not set\n- if 'b button action' is set to 'button ignored' then the b button doesn't do anything (such as cancelling)"
        },
        {
          "type": "block",
          "name": "dialog descriptions",
          "definition": "gui_dialog_description_block"
        },
        {
          "type": "explanation",
          "name": "Global datasources",
          "definition": "Datasources that are available from anywhere in the UI"
        },
        {
          "type": "block",
          "name": "global datasources",
          "definition": "datasource_definition_block"
        },
        {
          "type": "explanation",
          "name": "Content Aspect Ratio Scaling",
          "definition": "These define the scaling that will get applied to UI content and animations when running at the specified display modes"
        },
        {
          "type": "real_vector_2d",
          "name": "16x9"
        },
        {
          "type": "real_vector_2d",
          "name": "4x3"
        },
        {
          "type": "explanation",
          "name": "Blur Constants",
          "definition": "These control the blur kernel used when blurring overlayed UI"
        },
        {
          "type": "real",
          "name": "horizontal blur factor"
        },
        {
          "type": "real",
          "name": "vertical blur factor"
        },
        {
          "type": "explanation",
          "name": "Player Appearance Bipeds",
          "definition": "One element per player model choice.\r\nEach specifies the bipeds needed for player appearance (customization and roster)."
        },
        {
          "type": "block",
          "name": "player appearance bipeds",
          "definition": "player_appearance_bipeds_block"
        },
        {
          "type": "explanation",
          "name": "Hollywood Squares Flags",
          "definition": "These are the names of the cinematic cutscene flags used to place player appearance models in the Hollywood Squares (for display in the roster)."
        },
        {
          "type": "string_id",
          "name": "player 0 flag"
        },
        {
          "type": "string_id",
          "name": "player 1 flag"
        },
        {
          "type": "string_id",
          "name": "player 2 flag"
        },
        {
          "type": "string_id",
          "name": "player 3 flag"
        },
        {
          "type": "explanation",
          "name": "Hollywood Squares Camera Alignment Biped",
          "definition": "These fields specify the biped that stands behind the Hollywood Squares, and on which the camera will be focused to capture the Hollywood Squares.\r\nIf you want to use a scenario-placed biped (non-AI), enter the biped name in the 'biped name' field.\r\nIf you want to use an AI-placed biped, enter the squad name string and start position string_id."
        },
        {
          "type": "string",
          "name": "biped name"
        },
        {
          "type": "string",
          "name": "AI squad name"
        },
        {
          "type": "string_id",
          "name": "AI start pos"
        },
        {
          "type": "explanation",
          "name": "Playable Campaign Characters",
          "definition": "These fields specify the bipeds that show in the campaign lobby roster for the first player.\r\nIf you want to use a scenario-placed biped (non-AI), enter the biped name in the 'biped name' field.\r\nIf you want to use an AI-placed biped, enter the squad name string and start position string_id."
        },
        {
          "type": "string",
          "name": "rookie biped name"
        },
        {
          "type": "string",
          "name": "rookie AI squad name"
        },
        {
