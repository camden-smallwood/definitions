        {
          "type": "block",
          "name": "gravemind properties",
          "definition": "ai_globals_gravemind_block"
        },
        {
          "type": "real",
          "name": "scary target threhold#A target of this scariness is officially considered scary (by combat dialogue, etc.)"
        },
        {
          "type": "real",
          "name": "scary weapon threhold#A weapon of this scariness is officially considered scary (by combat dialogue, etc.)"
        },
        {
          "type": "real",
          "name": "player scariness"
        },
        {
          "type": "real",
          "name": "berserking actor scariness"
        },
        {
          "type": "real",
          "name": "kamikazeing actor scariness"
        },
        {
          "type": "real",
          "name": "invincible scariness#when an actor's target is invincible, he is this much more scared"
        },
        {
          "type": "real",
          "name": "morph delay (ranged):seconds#How long I have to wait after transforming to a ranged form before transforming again"
        },
        {
          "type": "real",
          "name": "morph delay (tank):seconds#How long I have to wait after transforming to a tank form before transforming again"
        },
        {
          "type": "real",
          "name": "morph delay (stalker):seconds#How long I have to wait after transforming to a stalker form before transforming again"
        },
        {
          "type": "explanation",
          "name": "RESURRECTION",
          "definition": "A few properties to help define when it is safe for a mission critical character to resurrect."
        },
        {
          "type": "real",
          "name": "min death time:seconds#I will be dead for at least this long"
        },
        {
          "type": "real",
          "name": "projectile distance:wu#If there is a projectile within this distance of me, I'll stay dead"
        },
        {
          "type": "real",
          "name": "idle clump distance:wu#If there is any enemy clump within this distance of me, I'll stay dead"
        },
        {
          "type": "real",
          "name": "dangerous clump distance:wu#If there is any enemy clump with a status higher than idle within this distance of me, I'll stay dead"
        },
        {
          "type": "long_integer",
          "name": "maximum active AI count#If there are more than this many active AI, swarm resurrection will not be attempted"
        },
        {
          "type": "long_integer",
          "name": "resurrection count limit per body#If a body has been resurrected this many times, we will not try to resurrect it again.  -1 is uncapped.  Carried across hostile morphs, so infecting a marine would count as its first resurrection."
        },
        {
          "type": "explanation",
          "name": "TELEPORTATION",
          "definition": "A few properties to help define when it is safe for a mission critical character to teleport."
        },
        {
          "type": "real",
          "name": "cover search duration:seconds#The number of seconds that must elapse before we try to look for a firing point behind cover to teleport to."
        },
        {
          "type": "real",
          "name": "task direction search duration:seconds#The number of seconds we try to look for a firing point that aligns us with the actor's task direction."
        },
        {
          "type": "block",
          "name": "spawn formations",
          "definition": "ai_globals_formation_block"
        },
        {
          "type": "block",
          "name": "squad template folders",
