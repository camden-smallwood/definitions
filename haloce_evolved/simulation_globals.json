      "size_string": "sizeof(s_simulation_universal_globals_definition)",
      "fields": [
        {
          "type": "explanation",
          "name": "SIMULATION DEPENDENCIES",
          "definition": "Each game engine enables various game systems which have associated entities for stateful replication in the distributed simulation. Some dependencies (like players and game engine globals) are foundational and the game is unlikely to function without them. Others are more bespoke: if your engine supports AI actors, you'll have a depdency on ai globals so allegience state is replicated to clients."
        },
        {
          "type": "custom",
          "name": "shared dependencies",
          "group_tag": "fgrb"
        },
