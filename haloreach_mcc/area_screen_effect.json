    "single_screen_effect": {
      "guid": "369b552ea746354e291eaea19f23aa90",
      "size": 240,
      "size_string": "sizeof(s_single_screen_effect_definition)",
      "flags": 1164,
      "fields": [
        {
          "type": "string_id",
          "name": "name^"
        },
        {
          "type": "word_flags",
          "name": "flags",
          "definition": "area_screen_effect_flags_definition"
        },
        {
          "type": "word_flags",
          "name": "hidden flags!",
          "definition": "area_screen_effect_hidden_flags_definition"
        },
        {
          "type": "explanation",
          "name": "DISTANCE FALLOFF",
          "definition": "controls the maximum distance and the distance falloff of this effect\nNOTE: not used for scenario global effects"
        },
        {
          "type": "real",
          "name": "maximum distance:world units#the maximum distance this screen effect will affect"
        },
        {
          "type": "struct",
          "name": "distance falloff",
          "definition": "screen_effect_scalar_function_struct"
        },
        {
          "type": "explanation",
          "name": "TIME EVOLUTION",
          "definition": "controls the lifetime and time falloff of this effect\nNOTE: not used for scenario global effects"
        },
        {
          "type": "real",
          "name": "delay:seconds#the effect will start after this many seconds (ignored if the play sequentially flag is set)"
        },
        {
          "type": "real",
          "name": "lifetime:seconds#the effect is destroyed after this many seconds (0 = never dies)"
        },
        {
          "type": "struct",
          "name": "time falloff",
          "definition": "screen_effect_scalar_function_struct"
        },
        {
          "type": "explanation",
          "name": "ANGLE FALLOFF",
          "definition": "controls the falloff of this effect based on how close you are to looking directly at it\nNOTE: not used for scenario global effects"
        },
        {
          "type": "struct",
          "name": "angle falloff",
          "definition": "screen_effect_scalar_function_struct"
        },
        {
          "type": "explanation",
          "name": "OBJECT FALLOFF",
          "definition": "applies a falloff based on an object function - ignored if the effect is not attached to an object"
        },
        {
          "type": "struct",
          "name": "object falloff",
          "definition": "screen_effect_scalar_object_function_struct"
        },
        {
          "type": "explanation",
          "name": "EFFECTS",
          "definition": "a selection of effects to choose from\nin the case of overlapping effects, the maximum will be taken"
        },
        {
          "type": "real",
          "name": "exposure boost:stops#increase in exposure"
        },
        {
          "type": "real",
          "name": "exposure deboost:stops#decrease in exposure"
        },
        {
          "type": "real",
          "name": "hue left:degrees [0-360]#shifts hue R->G->B"
        },
        {
          "type": "real",
          "name": "hue right:degrees [0-360]#shifts hue B->G->R"
        },
        {
          "type": "real",
          "name": "saturation:[0-1]#increases saturation"
        },
        {
          "type": "real",
          "name": "desaturation:[0-1]#decreases saturation"
        },
        {
          "type": "real",
          "name": "contrast enhance:[0-1]#contrast increase"
        },
        {
          "type": "real",
          "name": "gamma enhance:[0-10]#gamma increase"
        },
        {
          "type": "real",
          "name": "gamma reduce:[0-10]#gamma increase"
        },
        {
          "type": "real",
          "name": "bright noise:[0-1]#add bright noise contribution, 0 turns it off, 1: full on"
        },
        {
          "type": "real",
          "name": "dark noise:[0-1]#add dark noise contribution, 0 turns it off, 1: full on"
        },
        {
          "type": "real_rgb_color",
          "name": "color filter#this color is multiplied on top"
        },
        {
          "type": "real_rgb_color",
          "name": "color floor#this color is subtracted"
        },
        {
          "type": "real",
          "name": "tron:[0-1]#adds a full-screen tron effect"
        },
        {
          "type": "real",
          "name": "motion suck:[-2, 2]#adds motion-blur towards or away from this screen effect"
        },
        {
          "type": "real_vector_3d",
          "name": "motion suck direction!:[do not edit]#do not edit"
        },
        {
          "type": "real",
          "name": "horizontal blur:[0-10] expensive#blurs the entire screen"
        },
        {
          "type": "real",
          "name": "vertical blur:[0-10] expensive#blurs the entire screen"
        },
        {
          "type": "real",
          "name": "vision mode:[0-1]#turns on the global vision mode"
        },
        {
          "type": "real",
          "name": "hud fade:[0-1]#fades the chud"
        },
        {
          "type": "real",
          "name": "fov in:[0-1]#zooms in the field of view"
        },
        {
          "type": "real",
          "name": "fov out:[0-1]#zooms out the field of view"
        },
        {
          "type": "real",
          "name": "screen shake:[0-1]#shakes the entire screen"
        },
        {
          "type": "tag_reference",
          "name": "shader effect#applies this shader to the entire screen",
          "definition": {
            "flags": 0,
            "allowed": [
              "rmss"
            ]
          }
        },
        {
          "type": "terminator",
          "name": null
        }
      ],
      "source_file": "c:\\mcc\\qfe1\\reach\\shared\\engine\\source\\omaha\\effects\\screen_effect.cpp"
    },
