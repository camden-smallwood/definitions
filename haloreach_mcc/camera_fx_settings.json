    "camera_fx_exposure_struct": {
      "guid": "29ccbe1f704bc738479813af7bd65f3c",
      "size": 32,
      "size_string": "sizeof(c_camera_fx_settings::s_real_exposure_parameter)",
      "flags": 330,
      "fields": [
        {
          "type": "explanation",
          "name": "EXPOSURE",
          "definition": "Controls the brightness of the scene, like exposure time on your camera.\nThe actual exposure always blends towards the target exposure.\nWith auto-exposure on, the target exposure is calculated relative to the brightness of what is on screen.\n"
        },
        {
          "type": "word_flags",
          "name": "flags",
          "definition": "camera_fx_parameter_flags_auto_adjust"
        },
        {
          "type": "pad",
          "name": "MKRGRF",
          "definition": 2
        },
        {
          "type": "real",
          "name": "exposure:stops#the target exposure (ONLY USED WHEN AUTO-EXPOSURE IS OFF)"
        },
        {
          "type": "real",
          "name": "maximum change:stops#the maximum allowed change in exposure between frames"
        },
        {
          "type": "real",
          "name": "blend speed (0-1):percent per frame#1 is instantaneous, 0.01 is a good speed, 0.001 is slower"
        },
        {
          "type": "real",
          "name": "minimum:stops#the absolute target exposure is clamped to this range"
        },
        {
          "type": "real",
          "name": "maximum:stops#the absolute target exposure is clamped to this range"
        },
        {
          "type": "real",
          "name": "auto-exposure screen brightness:[0.0001-1]#how bright you want the screen to be - auto-exposure will make it happen"
        },
        {
          "type": "real",
          "name": "auto-exposure delay:[0.1-1]seconds#how long to wait before auto-exposure kicks in to adjust the exposure"
        },
        {
          "type": "terminator",
          "name": null
        }
      ],
      "source_file": "c:\\mcc\\qfe1\\reach\\shared\\engine\\source\\omaha\\render\\camera_fx_settings.cpp"
    },
