      "fields": [
        {
          "type": "explanation",
          "name": "Cheap Lights",
          "definition": "These are the cheapest light possible. They are spherical, have a color with an intensity and a radius - and that's it. They should be small: 0.5 or smaller if you can get close to them. That's why they are so cheap."
        },
        {
          "type": "explanation",
          "name": "COLOR",
          "definition": "color and intensity of the light"
        },
        {
          "type": "struct",
          "name": "color",
          "definition": "light_color_function_struct"
        },
        {
          "type": "struct",
          "name": "intensity",
          "definition": "light_scalar_function_struct"
        },
        {
          "type": "explanation",
          "name": "SIZE",
          "definition": "radius of the spherical light"
        },
        {
          "type": "struct",
          "name": "radius",
          "definition": "light_scalar_function_struct"
        },
        {
          "type": "real",
          "name": "falloff:[0-1]#how wide the falloff is relative to the radius"
        },
        {
          "type": "real",
          "name": "closeup fading distance:world units"
        },
        {
          "type": "terminator",
          "name": null
        }
      ],
