      "flags": 304,
      "fields": [
        {
          "type": "explanation",
          "name": "Emblem Library",
          "definition": "This library contains the definitions of all the player emblems\nAll the compositions and transformations that build an emblem are defined in this tag.\nEach emblem is composed of a number of shapes.\nAnd each shape is defined by transformations on an emblem bitmap.\n"
        },
        {
          "type": "short_integer",
          "name": "version!"
        },
        {
          "type": "pad",
          "name": "jfejkjjg",
          "definition": 2
        },
        {
          "type": "custom",
          "name": "Bitmaps",
          "group_tag": "fgrb"
        },
        {
          "type": "explanation",
          "name": "Bitmaps",
          "definition": "\n"
        },
        {
          "type": "real",
          "name": "bitmap resolution:pixels#used to calculate appropriate antialiasing settings"
        },
        {
          "type": "real",
          "name": "antialias sharpen#default 1.0, global control on antialias sharpness"
        },
        {
          "type": "tag_reference",
          "name": "emblem bitmaps",
          "definition": {
            "flags": 0,
            "allowed": [
              "bitm"
            ]
          }
        },
        {
          "type": "tag_reference",
