          "type": "byte_flags",
          "name": "flags",
          "definition": "game_engine_event_flags_definition"
        },
        {
          "type": "string_id",
          "name": "primary string#This string can use a bunch of neat tokens for substitution of runtime data (e.g. player names).  See an engineer for more info."
        },
        {
          "type": "long_integer",
          "name": "primary string duration:seconds"
        },
        {
          "type": "real",
          "name": "sound delay (announcer only)#After we commit to playing this sound, wait this long to actually play it.  Used to control announcer cadence."
        },
        {
          "type": "struct",
          "name": "default_sound",
          "definition": "sound_response_definition_struct"
        },
        {
          "type": "explanation",
          "name": "SOUND PRIORITIZATION",
          "definition": "A data-driven way to choose between halo 3 mp's always-queue behavior vs. odst firefight's always-suppress-older-multikills behavior."
        },
        {
          "type": "string_id",
          "name": "category_for_prioritization#which family does this response live in for announcer-spew-suppression?  e.g. all multi-kills should use the same string_id here."
        },
        {
          "type": "long_integer",
          "name": "sound priority#higher numbers mean more important"
        },
        {
          "type": "real",
          "name": "priority_suppression_age_max_seconds:seconds#If a sound from this event has been queued for more than this long, it can't be suppressed anymore.  Higher values cause a shallower announcer queue for these sounds."
        },
        {
          "type": "explanation",
          "name": "SOUND PAIR CULLING",
          "definition": "A way to say flag taken + flag dropped = silence."
        },
        {
          "type": "string_id",
          "name": "category_for_pair_culling#e.g. flag taken and flag dropped should use the same id here, while ball taken and ball dropped should use another shared id."
        },
        {
          "type": "long_integer",
          "name": "pair_id#0 or 1, used to recognized matched pairs.  If both a 0 and a 1 are in the queue at the same time, and neither has started playing, both are removed."
        },
        {
          "type": "real",
          "name": "delay_before_considering_sound_seconds:seconds#Used to keep a sound in the queue so later sounds can priority-suppress or pair-suppress it"
        },
        {
          "type": "block",
          "name": "sound permutations",
          "definition": "sound_response_definition_block"
        },
        {
          "type": "terminator",
          "name": null
        }
