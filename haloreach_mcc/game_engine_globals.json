          "definition": 2
        },
        {
          "type": "string_id",
          "name": "display string#This string can use a bunch of neat tokens for substitution of runtime data (e.g. player names).  See an engineer for more info."
        },
        {
          "type": "char_enum",
          "name": "required field",
          "definition": "game_engine_event_input_enum_definition"
        },
        {
