  "structs": {
    "light_struct_definition": {
      "guid": "f2b91e672d48afb6250f2d90a165b6ed",
      "size": 204,
      "size_string": "sizeof(struct light_definition)",
      "flags": 244,
      "fields": [
        {
          "type": "explanation",
          "name": "LIGHT METHOD",
          "definition": "Method..........Quality..Gels..Shadows.Transparents.Spotlight..Usage\n\nScreenspace.....Low......Yes.....No..........No..............No..........Cheap low quality lights\nInline...............Medium...No......No..........Yes.............Yes.........Large lights, affect transparents\nRe-render.........High.......Yes.....Yes.........No..............Yes.........High quality, shadowing lights"
        },
        {
          "type": "char_enum",
          "name": "light method:choose the method to render this light",
          "definition": "light_type_enum"
        },
        {
          "type": "char_integer",
          "name": "version!"
        },
        {
          "type": "word_flags",
          "name": "flags",
          "definition": "light_definition_flags"
        },
        {
          "type": "explanation",
          "name": "SHAPE",
          "definition": "shape of the light"
        },
        {
          "type": "short_enum",
          "name": "type",
          "definition": "light_type_enum_definition"
        },
        {
          "type": "pad",
          "name": "BUCU",
          "definition": 2
        },
        {
          "type": "real",
          "name": "attenuation end distance{maximum distance}:world units#maximum distance the light reaches (the light can become very dark well before this distance if you set your distance diffusion low)"
        },
        {
          "type": "real",
          "name": "attenuation start distance:world units#linear attenuation start"
        },
        {
          "type": "real",
          "name": "light/rain volume range#0 is far attenuation start point, 1 is the end point"
        },
        {
          "type": "real",
          "name": "frustum near width:world units#width of the frustum at the near plane"
        },
        {
          "type": "real",
          "name": "frustum height scale#how much the gel is stretched vertically (0.0 or 1.0 = aspect ratio same as gel)"
        },
        {
          "type": "real",
          "name": "frustum field of view:degrees#horizontal angle that the frustum light covers (0.0 = no spread, a straight beam of light)"
        },
        {
          "type": "real",
          "name": "angular hotspot{angular smoothness}#inner falloff angle"
        },
        {
          "type": "real",
          "name": "angular falloff speed:[1 - 12]#1.0 for sharp edges, greater than 1.0 for smooth edges"
        },
        {
          "type": "real",
          "name": "distance diffusion!:[0.01 - 10.0+]#approximately the physical size in world units of the light source itself.  small values cause the light to become very bright close to the light source, but quickly die off as you move away"
        },
        {
          "type": "real",
          "name": "near fading distance:world units"
        },
        {
          "type": "explanation",
          "name": "SHADOW",
          "definition": "shadow cutoff and quality settings"
        },
        {
          "type": "real",
          "name": "shadow cutoff distance"
        },
        {
          "type": "short_enum",
          "name": "shadow quality",
          "definition": "light_shadow_quality_enumeration"
        },
        {
          "type": "pad",
          "name": "ADEF",
          "definition": 2
        },
        {
          "type": "explanation",
          "name": "COLOR",
          "definition": "color and intensity of the light"
        },
        {
          "type": "struct",
          "name": "color",
          "definition": "light_color_function_struct"
        },
        {
          "type": "struct",
          "name": "intensity",
          "definition": "light_scalar_function_struct"
        },
        {
          "type": "tag_reference",
          "name": "gel bitmap:requires 'expensive light'",
          "definition": {
            "flags": 0,
            "allowed": [
              "bitm"
            ]
          }
        },
        {
          "type": "real",
          "name": "rain light reduction#0 means no reduction, 1 means completely removed"
        },
        {
          "type": "explanation",
          "name": "LIFETIME",
          "definition": "controls the lifetime of unattached lights"
        },
        {
          "type": "real",
          "name": "destroy light after:seconds#automatically destroys the light after it has existed this long (0 to disable)"
        },
        {
          "type": "explanation",
          "name": "LIGHT PRIORITY PARAMETERS",
          "definition": "Sets priorities on lights, to identify the best ones to render with\nYou can choose priorities for near and far, as well as what distance it transitions between the two"
        },
        {
          "type": "char_enum",
          "name": "near priority#priority when the light is fullscreen in size",
          "definition": "light_priority_enumeration"
        },
        {
          "type": "char_enum",
          "name": "far priority#priority when the light is very far away",
          "definition": "light_priority_enumeration"
        },
        {
          "type": "pad",
          "name": "RIIROERI",
          "definition": 2
        },
        {
          "type": "explanation",
          "name": "ATTACHMENTS",
          "definition": "Everything you can attach to a light"
        },
        {
          "type": "tag_reference",
          "name": "Lens Flare",
          "definition": {
            "flags": 0,
            "allowed": [
              "lens"
            ]
          }
        },
        {
          "type": "explanation",
          "name": "CLIP PLANES",
          "definition": "Clips the light volume against a plane, only useable by spherical screenspace lights)"
        },
        {
          "type": "long_flags",
          "name": "clip flags",
          "definition": "light_clip_flags_definition"
        },
        {
          "type": "long_integer",
          "name": "unused_padding_dont_touch!"
        },
        {
          "type": "real",
          "name": "clip +x:world units"
        },
        {
          "type": "real",
          "name": "clip -x:world units"
        },
        {
          "type": "real",
          "name": "clip +y:world units"
        },
        {
          "type": "real",
          "name": "clip -y:world units"
        },
        {
          "type": "real",
          "name": "clip +z:world units"
        },
        {
          "type": "real",
          "name": "clip -z:world units"
        },
        {
          "type": "terminator",
          "name": null
        }
      ],
      "source_file": "c:\\mcc\\qfe1\\reach\\shared\\engine\\source\\omaha\\objects\\light_definitions.cpp"
    },
