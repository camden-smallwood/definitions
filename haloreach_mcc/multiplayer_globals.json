    "multiplayer_constants_block": {
      "guid": "962afc8f0342dfd891ddf5bb5a1ec6e6",
      "size": 304,
      "size_string": "sizeof(struct s_multiplayer_constants)",
      "flags": 158,
      "fields": [
        {
          "type": "explanation",
          "name": "PLAYER SPAWN INFLUENCERS",
          "definition": "These are things that influence player spawn points"
        },
        {
          "type": "explanation",
          "name": "ENEMY FORBID",
          "definition": "This is a tight cylinder around the player with a strong negative weight. It serves to protect players from spawning close to an enemy, or having and enemy spawn close to them."
        },
        {
          "type": "real",
          "name": "ef full weight radius:wu"
        },
        {
          "type": "real",
          "name": "ef fall-off radius:wu"
        },
        {
          "type": "block",
          "name": "ef falloff function#Multiplier applied to weight (domain is full weight radius to fall-off radius, range should be 0 to 1).",
          "definition": "spawn_influence_weight_falloff_function_block"
        },
        {
          "type": "real",
          "name": "ef upper height:wu"
        },
        {
          "type": "real",
          "name": "ef lower height:wu"
        },
        {
          "type": "real",
          "name": "ef weight"
        },
        {
          "type": "explanation",
          "name": "ENEMY BIAS",
          "definition": "This is a larger cylinder, with a size set specifically for the size of the map. It has a weak negative weight which falls to zero towards the outer radius. It serves to bias players away from spawning near enemies, or in enemy held areas."
        },
        {
          "type": "real",
          "name": "eb full weight radius:wu"
        },
        {
          "type": "real",
          "name": "eb fall-off radius:wu"
        },
        {
          "type": "block",
          "name": "eb falloff function#Multiplier applied to weight (domain is full weight radius to fall-off radius, range should be 0 to 1).",
          "definition": "spawn_influence_weight_falloff_function_block"
        },
        {
          "type": "real",
          "name": "eb upper height:wu"
        },
        {
          "type": "real",
          "name": "eb lower height:wu"
        },
        {
          "type": "real",
          "name": "eb weight"
        },
        {
          "type": "explanation",
          "name": "ALLY BIAS",
          "definition": "This is a larger cylinder, with a size set specifically for the size of the map. It has a weak positive weight which falls to zero towards the outer radius. It serves to bias players towards spawning with allies, or in areas which are controlled by friendly players."
        },
        {
          "type": "real",
          "name": "ab full weight radius:wu"
        },
        {
          "type": "real",
          "name": "ab fall-off radius:wu"
        },
        {
          "type": "block",
          "name": "ab falloff function#Multiplier applied to weight (domain is full weight radius to fall-off radius, range should be 0 to 1).",
          "definition": "spawn_influence_weight_falloff_function_block"
        },
        {
          "type": "real",
          "name": "ab upper height:wu"
        },
        {
          "type": "real",
          "name": "ab lower height:wu"
        },
        {
          "type": "real",
          "name": "ab weight"
        },
        {
          "type": "explanation",
          "name": "SELECTED ALLY BIAS",
          "definition": "Same as ALLY BIAS, but used when the ally is selected in the dead-camera."
        },
        {
          "type": "real",
          "name": "sab full weight radius:wu"
        },
        {
          "type": "real",
          "name": "sab fall-off radius:wu"
        },
        {
          "type": "block",
          "name": "sab falloff function#Multiplier applied to weight (domain is full weight radius to fall-off radius, range should be 0 to 1).",
          "definition": "spawn_influence_weight_falloff_function_block"
        },
        {
          "type": "real",
          "name": "sab upper height:wu"
        },
        {
          "type": "real",
          "name": "sab lower height:wu"
        },
        {
          "type": "real",
          "name": "sab weight"
        },
        {
          "type": "explanation",
          "name": "DEAD TEAMMATE BIAS",
          "definition": "Dead teammate influences are cylinders centered upon the body of a dead teammate (or the player\u0092s own dead body)."
        },
        {
          "type": "real",
          "name": "dt full weight radius:wu"
        },
        {
          "type": "real",
          "name": "dt fall-off radius:wu"
        },
        {
          "type": "block",
          "name": "dt falloff function#Multiplier applied to weight (domain is full weight radius to fall-off radius, range should be 0 to 1).",
          "definition": "spawn_influence_weight_falloff_function_block"
        },
        {
          "type": "real",
          "name": "dt upper height:wu"
        },
        {
          "type": "real",
          "name": "dt lower height:wu"
        },
        {
          "type": "real",
          "name": "dt weight"
        },
        {
          "type": "real",
          "name": "dead teammate influence duration:seconds"
        },
        {
          "type": "explanation",
          "name": "WEAPON INFLUENCERS",
          "definition": "These influencers are induced by weapons either weilded or carried in the player's backpack"
        },
        {
          "type": "block",
          "name": "weapon influencers",
          "definition": "weapon_spawn_influence_block"
        },
        {
          "type": "explanation",
          "name": "VEHICLE INFLUENCERS",
          "definition": "These influencers are induced by vehicles."
        },
        {
          "type": "block",
          "name": "vehicle influencers",
          "definition": "vehicle_spawn_influence_block"
        },
        {
          "type": "explanation",
