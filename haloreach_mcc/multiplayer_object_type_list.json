      "flags": 1149,
      "fields": [
        {
          "type": "explanation",
          "name": "MEGALO",
          "definition": "After changing this tag you will need to run the tool command multiplayer-generate-global-object-type-list (once) and rebuild the .mapinfo file for each multiplayer scenario in order to use the new objects in megalo"
        },
        {
          "type": "block",
          "name": "object types*",
          "definition": "multiplayer_object_type_block"
        },
        {
          "type": "block",
          "name": "weapons",
          "definition": "multiplayer_object_collection_block"
        },
        {
          "type": "block",
          "name": "vehicles",
          "definition": "multiplayer_object_collection_block"
        },
        {
          "type": "block",
          "name": "grenades",
          "definition": "multiplayer_object_collection_block"
        },
        {
          "type": "block",
          "name": "equipment",
          "definition": "multiplayer_object_collection_block"
        },
        {
          "type": "explanation",
          "name": "REMAPPING TABLES",
          "definition": "Note - if a remap table has a single element whose 'from' is NONE, then every object will be remapped to the 'to' object"
        },
        {
          "type": "block",
          "name": "weapon remapping",
          "definition": "multiplayer_weapon_remap_table_block"
        },
        {
          "type": "block",
