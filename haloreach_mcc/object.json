    "object_function_interpolation_block": {
      "guid": "3e87965a1c4c0dac41650b8a2e8d2846",
      "size": 24,
      "size_string": "sizeof(s_object_function_interpolation_definition)",
      "flags": 168,
      "fields": [
        {
          "type": "long_enum",
          "name": "interpolation mode",
          "definition": "object_function_interpolation_mode_enum"
        },
        {
          "type": "real",
          "name": "linear travel time:s#used by constant velocity"
        },
        {
          "type": "real",
          "name": "acceleration:1/s/s#used by linear acceleration"
        },
        {
          "type": "explanation",
          "name": "springs",
          "definition": "the damping ratio is c/(2*sqrt(k)). if this ratio is:\r\n= 0 : oscillates forever\r\n< 1 : oscillates with decreasing amplitude\r\n= 1 : reaches the target precisely and quickly (no oscillation)\r\n> 1 : reaches the target slowly\r\nthe higher the value of k, the quicker the system will reach the target value"
        },
        {
          "type": "real",
          "name": "spring k#used by damped spring\r\ndetermines acceleration by displacement"
        },
        {
          "type": "real",
          "name": "spring c#used by damped spring\r\ndetermines damping based on velocity"
        },
        {
          "type": "real",
          "name": "fraction:0-1#used by fractional\r\nhow mush of the distance to the target to cover each update"
        },
        {
          "type": "terminator",
          "name": null
        }
      ],
