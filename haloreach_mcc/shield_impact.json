  "structs": {
    "shield_impact_struct_definition": {
      "guid": "3679620cfa42663cfd412dad2f9b723f",
      "size": 480,
      "size_string": "sizeof(s_shield_parameters)",
      "flags": 77,
      "fields": [
        {
          "type": "explanation",
          "name": "Shield Controls",
          "definition": "You can use the following variables as inputs to the functions here, in addition to any object variables\n    shield_vitality        percentage of shield remaining\n    shield_intensity       mixture of recent and current damage (see below)\n    current_shield_damage\n    recent_shield_damage\n"
        },
        {
          "type": "word_flags",
          "name": "flags",
          "definition": "shield_flags"
        },
        {
          "type": "short_integer",
          "name": "version!"
        },
        {
          "type": "custom",
          "name": "Shield Intensity",
          "group_tag": "fgrb"
        },
        {
          "type": "explanation",
          "name": "Shield Intensity",
          "definition": "Shield intensity is a combination of recent damage and current damage.\nThese controls let you adjust the relative intensity contribution from each.\n'shield_intensity' can be used as an input to any of the animation function curves below."
        },
        {
          "type": "real",
          "name": "Recent Damage Intensity"
        },
        {
          "type": "real",
          "name": "Current Damage Intensity"
        },
        {
          "type": "custom",
          "name": null,
          "group_tag": "fgre"
        },
        {
          "type": "custom",
          "name": "Shield Edge",
          "group_tag": "fgrb"
        },
        {
          "type": "explanation",
          "name": "Shield Edge",
          "definition": "These controls allow you to define the location and width of the shield edges.\nThe edge is faded as a function of the surface normal with respect to the camera.\nRadius 1.0 corresponds to the glancing edges of the surface (the silhouette edges).\nRadius 0.0 corresponds to the area of the surface directly facing the camera (the center).\nYou can control separately the inner and outer fades."
        },
        {
          "type": "real",
          "name": "Depth Fade Range:world units"
        },
        {
          "type": "real",
          "name": "Outer Fade Radius:[0-1]"
        },
        {
          "type": "real",
          "name": "Center Radius:[0-1]"
        },
        {
          "type": "real",
          "name": "Inner Fade Radius:[0-1]"
        },
        {
          "type": "struct",
          "name": "Edge Glow Color",
          "definition": "shield_color_function_struct"
        },
        {
          "type": "struct",
          "name": "Edge Glow Intensity",
          "definition": "shield_scalar_function_struct"
        },
        {
          "type": "custom",
          "name": null,
          "group_tag": "fgre"
        },
        {
          "type": "custom",
          "name": "Plasma",
          "group_tag": "fgrb"
        },
        {
          "type": "explanation",
          "name": "Plasma",
          "definition": "These controls allow you to define the appearance of the plasma effect.\nThe plasma is calculated using the standard formula (1-abs(tex0-tex1))^(sharpness).\nTiling scale controls the spatial tiling of the plasma textures.\nScroll speed controls how fast the textures scroll on the surface.\nYou can specify separate sharpness values for the edge and the center.\n"
        },
        {
          "type": "real",
          "name": "Plasma Depth Fade Range:world units"
        },
        {
          "type": "tag_reference",
          "name": "Plasma Noise Texture 0",
          "definition": {
            "flags": 0,
            "allowed": [
              "bitm"
            ]
          }
        },
        {
          "type": "tag_reference",
          "name": "Plasma Noise Texture 1",
          "definition": {
            "flags": 0,
            "allowed": [
              "bitm"
            ]
          }
        },
        {
          "type": "real",
          "name": "Tiling Scale"
        },
        {
          "type": "real",
          "name": "Scroll Speed"
        },
        {
          "type": "real",
          "name": "Edge Sharpness"
        },
        {
          "type": "real",
          "name": "Center Sharpness"
        },
        {
          "type": "real",
          "name": "Plasma Outer Fade Radius:[0-1]"
        },
        {
          "type": "real",
          "name": "Plasma Center Radius:[0-1]"
        },
        {
          "type": "real",
          "name": "Plasma Inner Fade Radius:[0-1]"
        },
        {
          "type": "struct",
          "name": "Plasma Center Color",
          "definition": "shield_color_function_struct"
        },
        {
          "type": "struct",
          "name": "Plasma Center Intensity",
          "definition": "shield_scalar_function_struct"
        },
        {
          "type": "struct",
          "name": "Plasma Edge Color",
          "definition": "shield_color_function_struct"
        },
        {
          "type": "struct",
          "name": "Plasma Edge Intensity",
          "definition": "shield_scalar_function_struct"
        },
        {
          "type": "custom",
          "name": null,
          "group_tag": "fgre"
        },
        {
          "type": "custom",
          "name": "Extrusion Oscillation",
          "group_tag": "fgrb"
        },
        {
          "type": "explanation",
          "name": "Extrusion Oscillation",
          "definition": "These controls allow you to define the oscillation in the extrusion.\nThese textures are tiled and scrolled in the xy and yz planes, and their red channel is applied as an offset to the extrusion\nTiling scale controls the spatial tiling of the plasma textures.\nScroll speed controls how fast the textures scroll on the surface.\nYou can specify separate sharpness values for the edge and the center.\n"
        },
        {
          "type": "tag_reference",
          "name": "Oscillation Texture 0",
          "definition": {
            "flags": 0,
            "allowed": [
              "bitm"
            ]
          }
        },
        {
          "type": "tag_reference",
          "name": "Oscillation Texture 1",
          "definition": {
            "flags": 0,
            "allowed": [
              "bitm"
            ]
          }
        },
        {
          "type": "real",
          "name": "Oscillation Tiling Scale"
        },
        {
          "type": "real",
          "name": "Oscillation Scroll Speed"
        },
        {
          "type": "struct",
          "name": "Extrusion Amount",
          "definition": "shield_scalar_function_struct"
        },
        {
          "type": "struct",
          "name": "Oscillation Amplitude",
          "definition": "shield_scalar_function_struct"
        },
        {
          "type": "custom",
          "name": null,
          "group_tag": "fgre"
        },
        {
          "type": "custom",
          "name": "Hit Response",
          "group_tag": "fgrb"
        },
        {
          "type": "explanation",
          "name": "Hit Response",
          "definition": "These controls allow you to define the color variation in the area surrounding projectile impacts.\nYou can control the color, and the size of the colored area.\nThe default input is time since impact.\n"
        },
        {
          "type": "real",
          "name": "Hit Time:seconds"
        },
        {
          "type": "struct",
          "name": "Hit Color",
          "definition": "shield_color_function_struct"
        },
        {
          "type": "struct",
          "name": "Hit Radius",
          "definition": "shield_scalar_function_struct"
        },
        {
          "type": "custom",
          "name": null,
          "group_tag": "fgre"
        },
        {
          "type": "real_quaternion",
          "name": "edge_scales!"
        },
        {
          "type": "real_quaternion",
          "name": "edge_offsets!"
        },
        {
          "type": "real_quaternion",
          "name": "plasma_scales!"
        },
        {
          "type": "real_quaternion",
          "name": "depth_fade_params!"
        },
        {
          "type": "terminator",
          "name": null
        }
      ],
      "source_file": "c:\\mcc\\qfe1\\reach\\shared\\engine\\source\\omaha\\effects\\shield_impact_definitions.cpp"
    },
