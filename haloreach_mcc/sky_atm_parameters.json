    "sky_atm_parameters_struct_definition": {
      "guid": "ea53f2e62f4fc0073cb74abb2f658970",
      "size": 68,
      "size_string": "sizeof(c_sky_atm_parameters)",
      "flags": 187,
      "fields": [
        {
          "type": "explanation",
          "name": "THIS TAG IS NO LONGER USED",
          "definition": "WARNING:  THIS TAG IS NO LONGER USED\n\nInstead, you should use atmosphere_fog for your palette entries and atmosphere_globals for the scenario-wide settings\nI left this tag in so you can reference it when creating the new tags\n\n\n\n\n\n\n\n\n\n\n\n\n"
        },
        {
          "type": "explanation",
          "name": "Patchy Fog Global Parameters",
          "definition": "Fog Bitmap................Noise texture to use on the screen-aligned sheets of fog\nTexture repeat rate.......Scaling factor to apply to fog UV coordinates\nDistance between sheets...Separating distance between sheets of fog\nDepth fade factor.........Lower values (approaching 0) cause a smoother fade at scene boundaries. Larger values (1 or more) make for a sharp transition\n\nFalloff start distance....Distance (in world units) at which to begin fading out patchy fog (default: 5)\nDistance falloff power....Rate at which to begin attenuating patchy fog settings (default: 2)\nTransparent sort distance..Distance from the camera where we sort the patchy fog effect (default: 100)\n\n"
        },
        {
          "type": "tag_reference",
          "name": "Fog Bitmap",
          "definition": {
            "flags": 0,
            "allowed": [
              "bitm"
            ]
          }
        },
        {
          "type": "real",
          "name": "Texture repeat rate"
        },
        {
          "type": "real",
          "name": "Distance between sheets"
        },
        {
          "type": "real",
          "name": "Depth fade factor"
        },
        {
          "type": "real",
          "name": "Falloff start distance"
        },
        {
          "type": "real",
          "name": "Distance falloff power"
        },
        {
          "type": "real",
          "name": "Transparent sort distance"
        },
        {
          "type": "char_enum",
          "name": "Transparent sort layer",
          "definition": "global_sort_layer_enum_defintion"
        },
        {
          "type": "pad",
          "name": "UNdfdfdSED",
          "definition": 3
        },
        {
          "type": "block",
          "name": "atmosphere settings",
          "definition": "atmosphere_setting_block"
        },
