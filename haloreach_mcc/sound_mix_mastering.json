      "fields": [
        {
          "type": "explanation",
          "name": "mastering limiter",
          "definition": "Release is the Speed, in milliseconds, at which the limiter stops affecting audio after the audio drops below the limiter's threshold, which is specified by the Loudness member. "
        },
        {
          "type": "struct",
          "name": "limiter",
          "definition": "sound_mix_mastering_limiter_struct"
        },
        {
          "type": "explanation",
          "name": "channel gains",
          "definition": "5.1 gains applied before the final mastering voice"
        },
        {
          "type": "struct",
          "name": "gains",
          "definition": "sound_mix_channel_gains_struct"
        },
        {
          "type": "explanation",
          "name": "music",
          "definition": "26 band equalizer applied to the music"
        },
        {
          "type": "struct",
          "name": "music equalizer",
          "definition": "sound_mix_music_equalizer_struct"
        },
        {
          "type": "explanation",
          "name": "sfx",
          "definition": "26 band equalizer applied to the sfx"
        },
        {
          "type": "struct",
          "name": "sfx equalizer",
          "definition": "sound_mix_sfx_equalizer_struct"
        },
        {
          "type": "terminator",
          "name": null
        }
      ],
      "source_file": "c:\\mcc\\qfe1\\reach\\shared\\engine\\source\\omaha\\sound\\sound_definitions.cpp"
    },
