          "type": "real",
          "name": "min intensity:[0-1]#fully shadowed areas will have this relative intensity"
        },
        {
          "type": "real",
          "name": "falloff width#controls the shape of the shadow falloff curve"
        },
        {
          "type": "real",
          "name": "corner scale#controls shadow sensitivity to corners"
        },
        {
          "type": "real",
          "name": "corner bias#offsets corner sensitivity, generally to ignore shallow corners"
        },
        {
          "type": "real",
          "name": "bounds scale#controls the maximum shadow distance, as a ratio of the distance to the object"
        },
        {
          "type": "real",
          "name": "bounds offset#offsets the maximum shadow distance, generally to make a region of full darkness before fading"
        },
        {
          "type": "real",
          "name": "near clip:world units#completely removes ssao on anything closer than this"
